[configuration]
entry_symbol = "towerdefense_library_init"
compatibility_minimum = "4.4"

[libraries]
linux.debug.x86_64 = "res://bin/libtowerdefense.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libtowerdefense.linux.template_release.x86_64.so"
android.debug.arm64 = "res://bin/libtowerdefense.android.template_debug.arm64.so"
android.release.arm64 = "res://bin/libtowerdefense.android.template_release.arm64.so"
